{
  "name": "intellij-git-client",
  "displayName": "IntelliJ Git Client",
  "description": "IntelliJ-style changelists, diffs, and partial commits for VS Code.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Source Control"
  ],
  "activationEvents": [
    "*",
    "onStartupFinished",
    "onView:intellijGit.changelists"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "intellijGit",
          "title": "IntelliJ Git",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "intellijGit": [
        {
          "id": "intellijGit.changelists",
          "name": "Changelists"
        },
        {
          "id": "intellijGit.log",
          "name": "Git Log"
        },
        {
          "id": "intellijGit.branches",
          "name": "Branches"
        }
      ]
    },
    "commands": [
      {
        "command": "intellijGit.refresh",
        "title": "IntelliJ Git: Refresh"
      },
      {
        "command": "intellijGit.openDiffReview",
        "title": "IntelliJ Git: Open Diff Review"
      },
      {
        "command": "intellijGit.commitSelected",
        "title": "IntelliJ Git: Commit Selected Changes"
      },
      {
        "command": "intellijGit.refreshLog",
        "title": "IntelliJ Git: Refresh Log"
      },
      {
        "command": "intellijGit.openCommitDiff",
        "title": "IntelliJ Git: Open Commit Diff"
      },
      {
        "command": "intellijGit.copyCommitHash",
        "title": "IntelliJ Git: Copy Commit Hash"
      },
      {
        "command": "intellijGit.refreshBranches",
        "title": "IntelliJ Git: Refresh Branches"
      },
      {
        "command": "intellijGit.checkoutBranch",
        "title": "IntelliJ Git: Checkout Branch"
      },
      {
        "command": "intellijGit.forceCheckoutBranch",
        "title": "IntelliJ Git: Force Checkout Branch"
      },
      {
        "command": "intellijGit.stashChanges",
        "title": "IntelliJ Git: Stash Local Changes"
      },
      {
        "command": "intellijGit.listStashes",
        "title": "IntelliJ Git: List Stashes"
      },
      {
        "command": "intellijGit.createShelf",
        "title": "IntelliJ Git: Create Shelf"
      },
      {
        "command": "intellijGit.listShelves",
        "title": "IntelliJ Git: List Shelves"
      }
    ],
    "configuration": {
      "title": "IntelliJ Git",
      "properties": {
        "intellijGit.gitPath": {
          "type": "string",
          "default": "git",
          "description": "Path to the Git executable."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p . && vite build",
    "package": "npm run compile && vsce package --allow-star-activation --allow-missing-repository",
    "watch": "tsc -w -p .",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@preact/preset-vite": "^2.9.0",
    "@types/node": "^20.12.0",
    "@types/vscode": "^1.101.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^2.4.0",
    "eslint": "^8.57.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "preact": "^10.22.0"
  }
}
